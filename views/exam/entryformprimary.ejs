 <!-- script to create dynamic input box -->
  <script>
    const BASE_HEADER_COLUMNS = 5;
    const BASE_ROW_COLUMNS = 5;
    const totalWorksheetInput = document.getElementById('totalWorksheet');
    const headerRow = document.getElementById('headerRow');
    const increaseWorksheetBtn = document.getElementById('increaseWorksheet');
    const decreaseWorksheetBtn = document.getElementById('decreaseWorksheet');
    const studentData = <%- JSON.stringify(studentData) %>;
    let isPageLoading = true; // Flag to prevent autosave during initial page load

    function getCurrentWorksheetCount() {
      return Math.max(0, headerRow.children.length - BASE_HEADER_COLUMNS);
    }

    function createWorksheetSelect(reg, worksheetIndex) {
      // Create container for checkbox and select
      const container = document.createElement('div');
      container.style.display = 'flex';
      container.style.gap = '6px';
      container.style.alignItems = 'center';
      container.style.justifyContent = 'center';

      // Create checkbox
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.name = `worksheetCheckbox[${reg}][${worksheetIndex}]`;
      checkbox.dataset.reg = reg;
      checkbox.dataset.worksheetIndex = worksheetIndex;
      checkbox.style.width = '16px';
      checkbox.style.height = '16px';
      checkbox.style.cursor = 'pointer';
      checkbox.title = 'Check to apply grade to multiple worksheets';

      // Create select
      const input = document.createElement('select');
      const grades = ['A+', 'A', 'B+', 'B', 'C+', 'C', 'D', 'NG'];

      const defaultOption = document.createElement('option');
      defaultOption.value = '';
      defaultOption.text = 'Select Grade';
      defaultOption.selected = true;
      input.appendChild(defaultOption);

      grades.forEach((grade) => {
        const option = document.createElement('option');
        option.value = grade;
        option.text = grade;
        input.appendChild(option);
      });

      input.name = `worksheetGrades[${reg}][]`;
      input.dataset.reg = reg;
      input.dataset.worksheetIndex = worksheetIndex;
      input.style.flex = '1';
      
      input.addEventListener('change', function() {
        // Apply this value to all checked worksheets in this row
        applyGradeToCheckedWorksheets(reg, this.value, this);
        autoSave(input);
      });

      container.appendChild(checkbox);
      container.appendChild(input);
      return container;
    }

    function applyGradeToCheckedWorksheets(reg, gradeValue, sourceSelect) {
      console.log(`[GradeSync] Applying grade "${gradeValue}" to checked worksheets for reg ${reg}`);
      
      // Find all checkboxes for this student that are checked
      const checkedCheckboxes = document.querySelectorAll(`input[name^="worksheetCheckbox[${reg}]"]:checked`);
      console.log(`[GradeSync] Found ${checkedCheckboxes.length} checked worksheets`);
      
      checkedCheckboxes.forEach((checkbox) => {
        const worksheetIndex = checkbox.dataset.worksheetIndex;
        // Find the corresponding select for this worksheet
        const correspondingSelect = document.querySelector(`select[name="worksheetGrades[${reg}][]"][data-worksheet-index="${worksheetIndex}"]`);
        
        if (correspondingSelect && correspondingSelect !== sourceSelect) {
          console.log(`[GradeSync] Setting Worksheet ${worksheetIndex} for reg ${reg} to "${gradeValue}"`);
          correspondingSelect.value = gradeValue;
          
          // Trigger autosave for the changed selects
          autoSave(correspondingSelect);
        }
      });
    }

    // Autosave the total worksheet count for all students
    async function autoSaveWorksheetCount() {
      const totalWorksheet = totalWorksheetInput.value || 0;
      const param = new URLSearchParams(window.location.search);
      const studentClass = param.get('studentClass');
      const section = param.get('section');
      const subject = param.get('subject');
      const academicYear = param.get('academicYear');
      const terminal = param.get('terminal');

      // Don't skip - always save when user clicks +/- but skip if we're syncing during page load
      // Only skip if this is called from syncWorksheetColumns AND page is loading AND we're not manually clicking
      if (isPageLoading) {
        // During page load, skip autosave since we're just recreating columns
        console.log(`[WorksheetAutosave] ⏭️ Skipping autosave during page load`);
        return;
      }

      console.log(`\n📊 [WorksheetAutosave] ========== SAVING WORKSHEET COUNT ==========`);
      console.log(`[WorksheetAutosave] Class: ${studentClass}`);
      console.log(`[WorksheetAutosave] Section: ${section}`);
      console.log(`[WorksheetAutosave] Subject: ${subject}`);
      console.log(`[WorksheetAutosave] Terminal: ${terminal}`);
      console.log(`[WorksheetAutosave] Academic Year: ${academicYear}`);
      console.log(`[WorksheetAutosave] Total Worksheet Count to Save: ${totalWorksheet}`);
      console.log(`[WorksheetAutosave] Number of Students: ${studentData.length}`);
      
      // Show saving state
      totalWorksheetInput.style.backgroundColor = '#fef3c7'; // Light yellow
      totalWorksheetInput.style.borderColor = '#f59e0b'; // Orange border
      console.log(`[WorksheetAutosave] ⏳ Showing "saving" state (yellow border)...`);
      
      try {
        // Save worksheet count for each student
        const savePromises = studentData.map(student => {
          const reg = student.reg;
          const theorymarks = document.querySelector(`input[name="theorymarks[${reg}]"]`)?.value || 0;
          const attendance = document.querySelector(`input[name="attendance[${reg}]"]`)?.value || 0;
          const name = document.querySelector(`input[name="name[${reg}]"]`)?.value || '';
          const roll = document.querySelector(`input[name="roll[${reg}]"]`)?.value || '';
          const gender = document.querySelector(`input[name="gender[${reg}]"]`)?.value || '';
          const passMarks = document.getElementById('passMarks')?.value || 0;
          const practicalfullmarks = document.getElementById('practicalfullmarks')?.value || 0;
          const theoryfullmarks = document.getElementById('fullMarks')?.value || 0;

          const worksheekGrade = document.querySelectorAll(`select[name="worksheetGrades[${reg}][]"]`);
          let worksheetGrades = [];
          worksheekGrade.forEach((select) => {
            worksheetGrades.push(select.value);
          });

          const saveData = {
            reg,
            theorymarks: Number(theorymarks),
            attendance: Number(attendance),
            studentClass,
            section,
            subject,
            academicYear,
            terminal,
            name,
            roll,
            totalWorksheet: Number(totalWorksheet),
            worksheetGrades,
            gender,
            passMarks: Number(passMarks),
            practicalfullmarks: Number(practicalfullmarks),
            theoryfullmarks: Number(theoryfullmarks),
          };

          console.log(`  📝 Student ${roll} (${name}): totalWorksheet=${totalWorksheet}, theorymarks=${theorymarks}, attendance=${attendance}`);

          return fetch(`/entryform?studentClass=${studentClass}&section=${section}&subject=${subject}&academicYear=${academicYear}&terminal=${terminal}`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(saveData)
          });
        });

        console.log(`[WorksheetAutosave] 📤 Sending ${studentData.length} save requests to server...`);
        const responses = await Promise.all(savePromises);
        
        // Check if all responses are ok
        let allSuccess = true;
        let successCount = 0;
        responses.forEach((response, index) => {
          if (!response.ok) {
            console.error(`  ✗ Student ${index}: Failed (Status ${response.status})`);
            allSuccess = false;
          } else {
            successCount++;
          }
        });

        if (allSuccess) {
          console.log(`✅ [WorksheetAutosave] ALL ${successCount} saves completed successfully!`);
          console.log(`✅ [WorksheetAutosave] Worksheet count saved: ${totalWorksheet}`);
          
          // Show success state
          totalWorksheetInput.style.backgroundColor = '#e0f2fe'; // Light blue
          totalWorksheetInput.style.borderColor = '#7dd3fc'; // Light blue border
          console.log(`[WorksheetAutosave] ✅ Showing "success" state (blue border)...`);
        } else {
          console.error(`❌ [WorksheetAutosave] ${studentData.length - successCount} saves failed out of ${studentData.length}`);
          totalWorksheetInput.style.backgroundColor = '#fee2e2'; // Light red
          totalWorksheetInput.style.borderColor = '#f87171'; // Red border
          console.log(`[WorksheetAutosave] ❌ Showing "error" state (red border)...`);
        }
        
        // Reset to normal after 2 seconds
        setTimeout(() => {
          totalWorksheetInput.style.backgroundColor = '';
          totalWorksheetInput.style.borderColor = '';
          console.log(`[WorksheetAutosave] Reset border color to normal`);
          console.log(`[WorksheetAutosave] ========== SAVE COMPLETE ==========\n`);
        }, 2000);
      } catch (err) {
        console.error(`❌ [WorksheetAutosave] ERROR:`, err);
        // Show error state
        totalWorksheetInput.style.backgroundColor = '#fee2e2'; // Light red
        totalWorksheetInput.style.borderColor = '#f87171'; // Red border
        
        // Reset to normal after 2 seconds
        setTimeout(() => {
          totalWorksheetInput.style.backgroundColor = '';
          totalWorksheetInput.style.borderColor = '';
          console.log(`[WorksheetAutosave] ========== SAVE FAILED ==========\n`);
        }, 2000);
      }
    }

    function addWorksheetColumn() {
      const currentCount = getCurrentWorksheetCount();
      const nextIndex = currentCount + 1;
      
      console.log(`[+Button] === ADD WORKSHEET COLUMN ===`);
      console.log(`[+Button] Current worksheet count: ${currentCount}`);
      console.log(`[+Button] Creating column ${nextIndex}`);
      
      const th = document.createElement('th');
      th.innerText = `Worksheet ${nextIndex} Marks`;
      headerRow.appendChild(th);
      console.log(`[+Button] ✓ Header created for Worksheet ${nextIndex}`);

      let selectsCreated = 0;
      studentData.forEach((student) => {
        const reg = student.reg;
        const rollInput = document.querySelector(`input[name="roll[${reg}]"]`);
        if (!rollInput) return;
        const row = rollInput.parentElement.parentElement;
        const td = document.createElement('td');
        // Pass the worksheet index (1-based) to createWorksheetSelect
        td.appendChild(createWorksheetSelect(reg, nextIndex));
        row.appendChild(td);
        selectsCreated++;
      });
      console.log(`[+Button] ✓ Created select dropdowns for ${selectsCreated} students`);

      totalWorksheetInput.value = getCurrentWorksheetCount();
      console.log(`[+Button] Updated totalWorksheet input to: ${totalWorksheetInput.value}`);
      console.log(`[+Button] Now calling autoSaveWorksheetCount()...`);
      autoSaveWorksheetCount(); // Save after adding column
      console.log(`[+Button] === END ADD ===\n`);
    }

    function canRemoveLastWorksheetColumn() {
      const currentCount = getCurrentWorksheetCount();
      if (currentCount <= 0) return true;

      const worksheetColumnIndex = BASE_ROW_COLUMNS + currentCount - 1;
      const rows = document.querySelectorAll('#markstable tr#dataEntryRow');
      for (const row of rows) {
        const cell = row.children[worksheetColumnIndex];
        if (!cell) continue;
        const select = cell.querySelector('select');
        if (select && select.value && select.value !== 'Select Grade') {
          return false;
        }
      }
      return true;
    }

    function removeWorksheetColumn() {
      const currentCount = getCurrentWorksheetCount();
      
      console.log(`[-Button] === REMOVE WORKSHEET COLUMN ===`);
      console.log(`[-Button] Current worksheet count: ${currentCount}`);
      
      if (currentCount <= 0) {
        console.log(`[-Button] ⚠️ No columns to remove (count is 0)`);
        totalWorksheetInput.value = 0;
        console.log(`[-Button] === END REMOVE ===\n`);
        return false;
      }

      // The worksheet number we're about to delete
      const worksheetToDelete = currentCount;
      console.log(`[-Button] Attempting to delete Worksheet ${worksheetToDelete}`);

      // Check if this column has data
      const rows = document.querySelectorAll('#markstable tr#dataEntryRow');
      let columnsWithData = [];
      
      rows.forEach((row) => {
        // Find ALL select elements with worksheetGrades names, then get the LAST one (the column to delete)
        const allSelects = row.querySelectorAll(`select[name^="worksheetGrades"]`);
        console.log(`[-Button] Row has ${allSelects.length} worksheet select elements`);
        
        if (allSelects.length >= currentCount) {
          // Get the last select (the one we're about to delete)
          const lastSelect = allSelects[allSelects.length - 1];
          console.log(`[-Button] Last select value: "${lastSelect.value}"`);
          
          if (lastSelect && lastSelect.value && lastSelect.value !== 'Select Grade') {
            // Try to find the roll number from the row
            const rollInput = row.querySelector(`input[name*="roll["]`);
            const roll = rollInput ? rollInput.value : 'Unknown';
            columnsWithData.push({ roll, grade: lastSelect.value });
            console.log(`[-Button] Data found - Roll: ${roll}, Grade: ${lastSelect.value}`);
          }
        }
      });

      console.log(`[-Button] Found ${columnsWithData.length} cells with data in Worksheet ${worksheetToDelete}`);
      
      // Show confirmation with specific details
      let confirmMessage = `Are you sure you want to delete Worksheet ${worksheetToDelete}?\n\n`;
      
      if (columnsWithData.length > 0) {
        confirmMessage += `⚠️ This column contains ${columnsWithData.length} marks that will be DELETED:\n\n`;
        columnsWithData.slice(0, 5).forEach(item => {
          confirmMessage += `  • Roll ${item.roll}: Grade ${item.grade}\n`;
        });
        if (columnsWithData.length > 5) {
          confirmMessage += `  • ... and ${columnsWithData.length - 5} more\n`;
        }
        confirmMessage += `\nClick OK to confirm deletion or Cancel to keep this column.`;
      } else {
        confirmMessage += `This column is empty.\n\nClick OK to delete or Cancel to keep.`;
      }

      console.log(`[-Button] Showing confirmation dialog:\n${confirmMessage}`);
      const confirmDelete = confirm(confirmMessage);
      
      if (!confirmDelete) {
        console.log(`[-Button] User cancelled deletion`);
        console.log(`[-Button] === END REMOVE ===\n`);
        return false;
      }
      
      console.log(`[-Button] User confirmed deletion of Worksheet ${worksheetToDelete}`);

      headerRow.removeChild(headerRow.lastChild);
      console.log(`[-Button] ✓ Header removed`);
      
      let deletedCount = 0;
      rows.forEach((row) => {
        // Find the last select element (the column to delete) and remove its parent td
        const allSelects = row.querySelectorAll(`select[name^="worksheetGrades"]`);
        if (allSelects.length > 0) {
          const lastSelect = allSelects[allSelects.length - 1];
          const lastTd = lastSelect.closest('td');
          if (lastTd && lastTd.parentElement === row) {
            lastTd.remove();
            deletedCount++;
            console.log(`[-Button] Removed cell with select for this row`);
          }
        }
      });
      console.log(`[-Button] ✓ Removed cells from ${deletedCount} rows`);

      totalWorksheetInput.value = getCurrentWorksheetCount();
      console.log(`[-Button] Updated totalWorksheet input to: ${totalWorksheetInput.value}`);
      console.log(`[-Button] Now calling autoSaveWorksheetCount()...`);
      autoSaveWorksheetCount(); // Save after removing column
      console.log(`[-Button] === END REMOVE ===\n`);
      return true;
    }

    function syncWorksheetColumns(desiredCount) {
      let target = Number(desiredCount);
      if (Number.isNaN(target) || target < 0) {
        target = 0;
      }

      let current = getCurrentWorksheetCount();
      while (current < target) {
        addWorksheetColumn();
        current = getCurrentWorksheetCount();
      }

      while (current > target) {
        const removed = removeWorksheetColumn();
        if (!removed) break;
        current = getCurrentWorksheetCount();
      }

      totalWorksheetInput.value = current;
    }

    totalWorksheetInput.addEventListener('input', function() {
      console.log(`[Input Event] totalWorksheet input changed to: ${totalWorksheetInput.value}`);
      syncWorksheetColumns(totalWorksheetInput.value);
    });

    increaseWorksheetBtn.addEventListener('click', function() {
      console.log(`\n🔵 [+BUTTON CLICKED] Adding worksheet column...`);
      addWorksheetColumn();
    });

    decreaseWorksheetBtn.addEventListener('click', function() {
      console.log(`\n🔴 [-BUTTON CLICKED] Removing worksheet column...`);
      removeWorksheetColumn();
    });
  </script>

