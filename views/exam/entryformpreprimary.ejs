<!-- script for autosave the data -->
<script>
  const saveTimers = new Map();

  async function autoSave(el) {
    const reg = el.dataset.reg;
    
    if (!reg) {
      return;
    }

    el.style.backgroundColor = '';
    el.style.borderColor = '';

    if (saveTimers.has(el)) {
      clearTimeout(saveTimers.get(el));
    }

    const timer = setTimeout(async () => {
      // Get theory grade from select
      const gradeSelect = document.querySelector(`select[name="theoryGrade[${reg}]"]`);
      const theorymarks = gradeSelect ? gradeSelect.value : 0;
      
      // Update hidden input
      const theoryHidden = document.querySelector(`input[name="theorymarks[${reg}]"]`);
      if (theoryHidden) {
        theoryHidden.value = theorymarks;
      }
      
      const attendance = document.querySelector(`input[name="attendance[${reg}]"]`)?.value || 0;
      const param = new URLSearchParams(window.location.search);
      const studentClass = param.get('studentClass');
      const section = param.get('section');
      const subject = param.get('subject');
      const academicYear = param.get('academicYear');
      const terminal = param.get('terminal');
      const name = document.querySelector(`input[name="name[${reg}]"]`)?.value || '';
      const roll = document.querySelector(`input[name="roll[${reg}]"]`)?.value || '';
      const gender = document.querySelector(`input[name="gender[${reg}]"]`)?.value || '';
      const passMarks = document.getElementById('passMarks')?.value || 0;
      const practicalfullmarks = document.getElementById('practicalfullmarks')?.value || 0;
      const theoryfullmarks = document.getElementById('fullMarks')?.value || 0;
      const totalWorksheet = Number(document.getElementById('totalWorksheet')?.value || 1);
      // Merge visible value(s) with the in-memory store so unseen worksheet grades are preserved.
      const baseGrades = Array.from({ length: totalWorksheet }, (_, i) => {
        const stored = worksheetGradeStore.get(reg) || [];
        return stored[i] || '';
      });
      const visibleSelects = Array.from(document.querySelectorAll(`select[name="worksheetGrades[${reg}][]"]`));
      visibleSelects.forEach((vis) => {
        const idx = Number(vis.dataset.worksheetIndex) || currentWorksheetNumber;
        if (idx >= 1 && idx <= totalWorksheet) {
          baseGrades[idx - 1] = vis.value || '';
        }
      });
      const worksheetGrades = baseGrades;

      const saveData = {
        reg,
        theorymarks: Number(theorymarks),
        attendance: Number(attendance),
        studentClass,
        section,
        subject,
        academicYear,
        terminal,
        name,
        roll,
        totalWorksheet,
        worksheetGrades,
        gender,
        passMarks: Number(passMarks),
        practicalfullmarks: Number(practicalfullmarks),
        theoryfullmarks: Number(theoryfullmarks),
      };

      try {
        const response = await fetch(`/entryform?studentClass=${studentClass}&section=${section}&subject=${subject}&academicYear=${academicYear}&terminal=${terminal}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(saveData)
        });
        if (response.ok) {
          el.style.backgroundColor = '#e0f2fe';
          el.style.borderColor = '#7dd3fc';
          el.style.transition = 'background-color 0.3s ease';
        }
      } catch (err) {
        console.error(`AutoSave error for reg ${reg}:`, err);
      }
      saveTimers.delete(el);
    }, 1000);

    saveTimers.set(el, timer);
  }
</script>

<script>
  const totalWorksheetInput = document.getElementById('totalWorksheet');
  const worksheetCountSelect = document.getElementById('worksheetCountSelect');
  const increaseWorksheetBtn = document.getElementById('increaseWorksheetBtn');
  const decreaseWorksheetBtn = document.getElementById('decreaseWorksheetBtn');
  const headerRow = document.getElementById('headerRow');
  const studentData = <%- JSON.stringify(studentData).replace(/</g, '\u003c') %>;
  const worksheetGradeStore = new Map();
  const hideAttendanceToggle = document.getElementById('hideAttendanceToggle');
  const hideMarksToggle = document.getElementById('hideMarksToggle');
  const markstable = document.getElementById('markstable');
  let isPageLoading = true;
  let currentWorksheetNumber = 1;
  let maxWorksheetNumber = 10;

  function syncMobileColumnToggles() {
    if (!markstable || !hideAttendanceToggle || !hideMarksToggle) return;

    const savedHideAttendance = localStorage.getItem('entryformHideAttendance') === '1';
    const savedHideMarks = localStorage.getItem('entryformHideMarks') === '1';

    hideAttendanceToggle.checked = savedHideAttendance;
    hideMarksToggle.checked = savedHideMarks;
    markstable.classList.toggle('hide-attendance', savedHideAttendance);
    markstable.classList.toggle('hide-theory', savedHideMarks);

    hideAttendanceToggle.addEventListener('change', function () {
      localStorage.setItem('entryformHideAttendance', this.checked ? '1' : '0');
      markstable.classList.toggle('hide-attendance', this.checked);
    });

    hideMarksToggle.addEventListener('change', function () {
      localStorage.setItem('entryformHideMarks', this.checked ? '1' : '0');
      markstable.classList.toggle('hide-theory', this.checked);
    });
  }

  function updateWorksheetHeader(number) {
    const headerNumber = document.getElementById('worksheetHeaderNumber');
    if (headerNumber) {
      headerNumber.textContent = number;
    } else {
      const worksheetHeader = document.getElementById('worksheetHeader');
      if (worksheetHeader) worksheetHeader.textContent = `Worksheet ${number}`;
    }
  }

  function buildWorksheetOptions(count) {
    maxWorksheetNumber = Math.max(1, Number(count) || 1);
    if (worksheetCountSelect) {
      worksheetCountSelect.innerHTML = '';
      for (let i = 1; i <= maxWorksheetNumber; i++) {
        const option = document.createElement('option');
        option.value = i;
        option.textContent = `Worksheet ${i}`;
        worksheetCountSelect.appendChild(option);
      }
      if (currentWorksheetNumber > maxWorksheetNumber) {
        currentWorksheetNumber = maxWorksheetNumber;
      }
      worksheetCountSelect.value = String(currentWorksheetNumber);
    }
    if (totalWorksheetInput) {
      totalWorksheetInput.value = maxWorksheetNumber;
    }
    // Persist new totalWorksheet count to DB when user changes it (skip during initial load)
    if (!isPageLoading) {
      saveTotalWorksheetToDB(maxWorksheetNumber);
    }
  }

  async function saveTotalWorksheetToDB(total) {
    if (!totalWorksheetInput) return;
    totalWorksheetInput.style.backgroundColor = '#fef3c7';
    totalWorksheetInput.style.borderColor = '#f59e0b';

    const param = new URLSearchParams(window.location.search);
    const studentClass = param.get('studentClass');
    const section = param.get('section');
    const subject = param.get('subject');
    const academicYear = param.get('academicYear');
    const terminal = param.get('terminal');

    try {
        const savePromises = studentData.map((student) => {
        const reg = student.reg;
        const totalCount = Number(total);
        // Use stored grades as the base so reducing/persisting doesn't wipe unseen grades.
        const stored = worksheetGradeStore.get(reg) || [];
        const gradesBase = Array.from({ length: totalCount }, (_, i) => stored[i] || '');
        // If a select for this reg exists in the DOM, make sure its runtime value is included.
        const visible = Array.from(document.querySelectorAll(`select[name="worksheetGrades[${reg}][]"]`));
        visible.forEach((s) => {
          const idx = Number(s.dataset.worksheetIndex) || currentWorksheetNumber;
          if (idx >= 1 && idx <= totalCount) gradesBase[idx - 1] = s.value || '';
        });
        const worksheetGrades = gradesBase;
        const theoryHidden = document.querySelector(`input[name="theorymarks[${reg}]"]`);
        const theorymarks = theoryHidden ? theoryHidden.value : 0;
        const attendance = document.querySelector(`input[name="attendance[${reg}]"]`)?.value || 0;
        const name = document.querySelector(`input[name="name[${reg}]"]`)?.value || '';
        const roll = document.querySelector(`input[name="roll[${reg}]"]`)?.value || '';
        const gender = document.querySelector(`input[name="gender[${reg}]"]`)?.value || '';
        const passMarks = document.getElementById('passMarks')?.value || 0;
        const practicalfullmarks = document.getElementById('practicalfullmarks')?.value || 0;
        const theoryfullmarks = document.getElementById('fullMarks')?.value || 0;

        const saveData = {
          reg,
          theorymarks: Number(theorymarks),
          attendance: Number(attendance),
          studentClass,
          section,
          subject,
          academicYear,
          terminal,
          name,
          roll,
          totalWorksheet: Number(totalCount),
          worksheetGrades,
          gender,
          passMarks: Number(passMarks),
          practicalfullmarks: Number(practicalfullmarks),
          theoryfullmarks: Number(theoryfullmarks),
        };

        return fetch(`/entryform?studentClass=${studentClass}&section=${section}&subject=${subject}&academicYear=${academicYear}&terminal=${terminal}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(saveData)
        });
      });

      const responses = await Promise.all(savePromises);
      const allSuccess = responses.every(r => r.ok);
      if (allSuccess) {
        totalWorksheetInput.style.backgroundColor = '#e0f2fe';
        totalWorksheetInput.style.borderColor = '#7dd3fc';
      } else {
        totalWorksheetInput.style.backgroundColor = '#fee2e2';
        totalWorksheetInput.style.borderColor = '#f87171';
      }
    } catch (err) {
      console.error('Failed to save totalWorksheet:', err);
      totalWorksheetInput.style.backgroundColor = '#fee2e2';
      totalWorksheetInput.style.borderColor = '#f87171';
    } finally {
      setTimeout(() => { totalWorksheetInput.style.backgroundColor = ''; totalWorksheetInput.style.borderColor = ''; }, 1200);
    }
  }

  function getWorksheetGrade(reg, worksheetNumber) {
    const grades = worksheetGradeStore.get(reg) || [];
    return grades[worksheetNumber - 1] || '';
  }

  function setWorksheetGrade(reg, worksheetNumber, grade) {
    const grades = worksheetGradeStore.get(reg) || [];
    grades[worksheetNumber - 1] = grade;
    worksheetGradeStore.set(reg, grades);
  }

  function buildWorksheetSelect(reg, worksheetNumber) {
    const container = document.createElement('div');
    container.className = 'worksheet-cell';

    const checkbox = document.createElement('input');
    checkbox.type = 'checkbox';
    checkbox.className = 'row-worksheet-checkbox';
    checkbox.dataset.reg = reg;
    checkbox.dataset.worksheetIndex = worksheetNumber;
    checkbox.title = 'Select student to apply grade to';

    const select = document.createElement('select');
    select.className = 'worksheet-select-inner';
    select.name = `worksheetGrades[${reg}][]`;
    select.dataset.reg = reg;
    select.dataset.worksheetIndex = worksheetNumber;

    const grades = ['', 'A+', 'A', 'B+', 'B', 'C+', 'C', 'D', 'NG'];
    grades.forEach((grade) => {
      const option = document.createElement('option');
      option.value = grade;
      option.textContent = grade || 'Select Grade';
      select.appendChild(option);
    });

    select.value = getWorksheetGrade(reg, worksheetNumber);

    select.addEventListener('change', function () {
      setWorksheetGrade(reg, worksheetNumber, this.value);
      if (typeof autoSave === 'function') autoSave(select); // ensure source select is saved immediately

      const applyAll = document.getElementById('worksheetApplyAll');
      const checkedBoxes = Array.from(document.querySelectorAll(`#markstable input.row-worksheet-checkbox[data-worksheet-index="${worksheetNumber}"]:checked`));

      if (applyAll && applyAll.checked) {
        // apply to all rows in this worksheet
        document.querySelectorAll(`#markstable select[data-worksheet-index="${worksheetNumber}"]`).forEach((s) => {
          if (s !== select) {
            s.value = select.value;
            setWorksheetGrade(s.dataset.reg, worksheetNumber, select.value);
            if (typeof autoSave === 'function') autoSave(s);
          }
        });
      } else if (checkedBoxes.length > 0) {
        // apply to selected rows only
        checkedBoxes.forEach((cb) => {
          const regKey = cb.dataset.reg;
          const s = document.querySelector(`#markstable select[data-worksheet-index="${worksheetNumber}"][data-reg="${regKey}"]`);
          if (s && s !== select) {
            s.value = select.value;
            setWorksheetGrade(regKey, worksheetNumber, select.value);
            if (typeof autoSave === 'function') autoSave(s);
          }
        });
        // uncheck the boxes after applying to selected
        checkedBoxes.forEach(cb => cb.checked = false);
      }
    });

    container.appendChild(checkbox);
    container.appendChild(select);
    return container;
  }

  function renderWorksheetCells(worksheetNumber) {
    updateWorksheetHeader(worksheetNumber);

    document.querySelectorAll('#markstable td[data-column="worksheet"]').forEach((td) => {
      const reg = td.dataset.reg;
      td.innerHTML = '';
      if (!reg) {
        return;
      }
      td.appendChild(buildWorksheetSelect(reg, worksheetNumber));
    });
    
    // After rendering worksheet cells, populate grades if we have data
    if (Object.keys(gradeDataFromDB).length > 0) {
      console.log("Worksheet rendered, populating grades...");
      setTimeout(populateAllGradesAfterRender, 100);
    }
  }

  function syncWorksheetSelection(desiredWorksheetNumber) {
    let target = Number(desiredWorksheetNumber);
    if (Number.isNaN(target) || target < 1) {
      target = 1;
    }
    if (target > maxWorksheetNumber) {
      buildWorksheetOptions(target);
    }
    currentWorksheetNumber = target;
    if (worksheetCountSelect) {
      worksheetCountSelect.value = String(currentWorksheetNumber);
    }
    renderWorksheetCells(currentWorksheetNumber);
  }

  if (worksheetCountSelect) {
    worksheetCountSelect.addEventListener('change', function () {
      syncWorksheetSelection(this.value);
    });
  }

  if (increaseWorksheetBtn) {
    increaseWorksheetBtn.addEventListener('click', function () {
      // Increase number of available worksheet options, do NOT change displayed worksheet
      buildWorksheetOptions(maxWorksheetNumber + 1);
    });
  }

  if (decreaseWorksheetBtn) {
    decreaseWorksheetBtn.addEventListener('click', function () {
      // Ask for confirmation before reducing available worksheets
      if (!confirm('Reduce available worksheet options? This will remove the highest worksheet option. Continue?')) {
        return;
      }
      if (maxWorksheetNumber <= 1) return;
      // Decrease available options
      buildWorksheetOptions(maxWorksheetNumber - 1);
      // If current displayed worksheet is now out of range, clamp and re-render
      if (currentWorksheetNumber > maxWorksheetNumber) {
        currentWorksheetNumber = maxWorksheetNumber;
        renderWorksheetCells(currentWorksheetNumber);
      }
    });
  }

  if (totalWorksheetInput) {
    totalWorksheetInput.addEventListener('input', function () {
      buildWorksheetOptions(this.value);
      if (currentWorksheetNumber > maxWorksheetNumber) {
        syncWorksheetSelection(maxWorksheetNumber);
      }
    });
  }

  syncMobileColumnToggles();

  // Start with a single worksheet option by default
  buildWorksheetOptions(1);
  syncWorksheetSelection(currentWorksheetNumber);
  isPageLoading = false;
</script>

