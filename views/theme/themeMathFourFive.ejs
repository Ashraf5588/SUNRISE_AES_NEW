<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%=subject%></title>
  <link rel="stylesheet" href="/form.css">
  <link rel="stylesheet" href="/mobile-form-enhancements.css">
 <script src="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/js/nepali.datepicker.v5.0.6.min.js" type="text/javascript"></script>
 <link href="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/css/nepali.datepicker.v5.0.6.min.css" rel="stylesheet" type="text/css"/>
 <style>
  .theme-selector-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 16px 0 20px;
    align-items: flex-end;
  }
  .theme-selector-group {
    display: flex;
    flex-direction: column;
    min-width: 220px;
    flex: 1;
  }
  .theme-selector-group label {
    font-weight: 600;
    margin-bottom: 6px;
    color: #2d3748;
  }
  .theme-selector-group select {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #cbd5e0;
    border-radius: 10px;
    background: #fff;
    font-size: 15px;
    color: #2d3748;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
  .theme-selector-group select:focus {
    outline: none;
    border-color: #ff8c42;
    box-shadow: 0 0 0 3px rgba(255,140,66,0.18);
  }
  @media (max-width: 768px) {
    .theme-selector-row {
      flex-direction: column;
      align-items: stretch;
    }
    .theme-selector-group {
      min-width: 0;
    }
    .theme-selector-group select {
      font-size: 16px;
      padding: 13px 14px;
    }
  }
 </style>
</head>
<body>
<%- include('../partials/mainnav') %>
<div class="theme-selector-row">
  <div class="theme-selector-group">
    <label for="classsectionselect">Class & Section</label>
    <select onchange="window.location.href = '/themeform?studentClass=' + this.value.split(' - ')[0] + '&section=' + this.value.split(' - ')[1] + '&terminal=<%= terminal %>&subject=<%= subject %>'" id="classsectionselect">
      <option disabled selected><%= studentClass %> - <%= section %></option>
      <%studentClassdata.forEach(data => { %>
        <option value="<%= data.studentClass %> - <%= data.section %>"><%= data.studentClass %> - <%= data.section %></option>
      <% }); %>
    </select>
  </div>
  <div class="theme-selector-group">
    <label for="subjectselect">Subject</label>
    <select id="subjectselect" onchange="window.location.href = '/themeform?studentClass=<%= studentClass %>&section=<%= section %>&terminal=<%= terminal %>&subject=' + this.value;">
      <option disabled selected><%= subject %></option>
      <% const uniqueSubjects = new Set(newsubjectList.map(item => item.newsubject)); %>
      
      <%uniqueSubjects.forEach(subject => { %>
        <option value="<%= subject %>"><%= subject %></option>
      <% }); %>
    </select>
  </div>
</div>
  <form action="/themeform?studentClass=<%= studentClass %>&section=<%= section %>&terminal=<%= terminal %>&subject=<%= subject %>" method="POST">

  
  
    Select theme:
    <select id="themeselect" onchange="filterLO()">
      <option disabled selected>Select Unit</option>
      <%themeData.forEach(data => { %>
        <% data.themes.forEach((theme,themeIndex) => { %>
          <option value="<%= theme.themeName %>" data-themeIndex="<%= themeIndex %>"><%=themeIndex+1%>.<%= theme.themeName %></option>
        <% }); %>
      <% }); %>
   
    </select> 
     <select id="aspectselect" onchange="filterAspect()" name="aspectName">
        <option disabled selected>Select Topic</option>
       
    </select>
    
     <select id="learningoutcomeselect" onchange="changeLo()">
        <option disabled selected>Select Learning Outcome</option>
    </select>
  
     <select id="toolselect" onchange="showTable()">
      <option selected disabled>Select Tool </otpion>
      <% toolDoc.tools.forEach(tool => { %>
        <option value="<%= tool %>"><%= tool%></option>
      <% }); %>
        
  
    </select>
<input type="hidden" value="<%=JSON.stringify(themeData)%>" id="themeData">

<input type="submit">

<input type="hidden" id="existingMap" value="<%=JSON.stringify(existingMap)%>"

 <th>Eval.Date Before: <input type="text" id="nepali-datepicker" class="masterDateBefore nepali-datepicker" placeholder="Select Nepali Date" /></th>
 <th>Eval.Date After: <input type="text" id="nepali-datepicker" class="masterDateAfter nepali-datepicker" placeholder="Select Nepali Date" /></th>

 <button type="button" id="applydate" onclick="loadDate()">Apply Date</button>
  <table border="1" cellspacing="0" cellpadding="5" class="themeTable" style="display:none;">
  

    <tr>
    
        <th>Eval.Date Before</th>
          <th>Name</th>
      <th>Indicator</th>
      <th>Obt.Marks Before</th>
      <th>Obt.Marks After</th>
      <th>Eval.Date After</th>
      
    </tr>
 <input type="hidden" value="<%= studentClass%>" name="studentClass">
           <input type="hidden" value="<%= section%>" name="section">
       <input type="hidden" value="<%= subject%>" name="subject">
    <input type="hidden"  id="selectedThemeName" name="themeName">
<input type="hidden"  id="selectedLOName" name="learningOutcomeName">
<input type="hidden"  id="toolname" name="toolName">

      <% studentData.forEach((record, idx) => { %>
    <tr>
    
       <input type="hidden" value="<%= record.reg%>" name="reg">
      <input type="hidden" value="<%= record.name%>" name="name">
      <input type="hidden" value="<%= record.roll%>" name="roll">
     

       

       <td><input type="text" id="nepali-datepicker-<%= idx %>" placeholder="Select Nepali Date"  class="studentDateBefore nepaliDateBefore nepali-datepicker" name="evalDateBefore" /></td>
         <td><%=record.roll%>. <%= record.name %></td>
      <td id="indicatorTD"></td>
      <input type="hidden" id="selectedIndicatorBefore">
       <input type="hidden" id="selectedIndicatorAfter">
      <td id="obtmarksbefore"></td>
      <td id="obtmarksafter"></td>
      <td><input type="text" id="nepali-datepicker-<%= idx %>" placeholder="Select Nepali Date"  
        class="studentDateAfter nepaliDateAfter nepali-datepicker" name="evalDateAfter"/></td>
    </tr>
    <%});%>
  </table> <br>

    </form>
<input type="hidden" value="<%=JSON.stringify(studentData)%>" id="studentData">
  <script>
const themeData = <%- JSON.stringify(themeData) %>;

function filterLO() {
    const selectedOption =
        document.querySelector('#themeselect option:checked');

    const selectedThemeIndex =
        Number(selectedOption.dataset.themeindex);

        // adding name for selected theme to save in db

        document.getElementById('selectedThemeName').value = themeData[0].themes[selectedThemeIndex].themeName;
          
    const selectedTheme =
        themeData[0].themes[selectedThemeIndex];
const aspectButton = document.getElementById('aspectselect');
aspectButton.innerHTML = '';

const uniqueAspects = new Map();
let aspectIndex = 0;

selectedTheme.learningOutcome.forEach((lo) => {
    lo.assessmentAspects.forEach((aspect) => {
        if (!uniqueAspects.has(aspect.aspectName)) {
            uniqueAspects.set(aspect.aspectName, aspectIndex++);
        }
    });
});

aspectButton.appendChild(new Option('Select Topic', '', true, true));

uniqueAspects.forEach((index, aspectName) => {
    console.log(aspectName, index);

    const option = new Option(aspectName, aspectName);
    option.dataset.aspectIndex = index;
    aspectButton.appendChild(option);
});

         


        

    const learningOutcomeSelect =
        document.getElementById('learningoutcomeselect');

    learningOutcomeSelect.innerHTML = '';

        
 const defaultLOoption = document.createElement('option');
 defaultLOoption.textContent="select Learning Outcome";
 defaultLOoption.disabled = true;
 defaultLOoption.selected = true;
 learningOutcomeSelect.appendChild(defaultLOoption);
    selectedTheme.learningOutcome.forEach(lo => {
        const option = document.createElement('option');

        option.value = lo.learningOutcomeName;
     
        option.textContent = lo.learningOutcomeName;

        learningOutcomeSelect.appendChild(option);
           
    });
}

</script>

<script>
    function showTable() {
    const tables = document.querySelectorAll(".themeTable");
    const indicatorTDs = document.querySelectorAll("#indicatorTD");
    const obtmarksbeforeTDs = document.querySelectorAll("#obtmarksbefore");
    const obtmarksafterTDs = document.querySelectorAll("#obtmarksafter");

    const selectedThemeIndex = document.getElementById("themeselect")
        .selectedOptions[0].dataset.themeindex;
    
    const selectedAspectName = document.getElementById("aspectselect").value;
    console.log("Selected Aspect Name:", selectedAspectName);

    const selectedLOName = document.getElementById("learningoutcomeselect").value;
    console.log("Selected LO Name:", selectedLOName);

    // Check if valid selections are made
    if (!selectedLOName || selectedLOName === "Select Learning Outcome") {
        console.log("No valid Learning Outcome selected");
        tables[0].style.display = "none";
        return;
    }

    tables[0].style.display = "block";

    const studentData = JSON.parse(document.getElementById("studentData").value);
    const selectedToolName = document.getElementById("toolselect").value;
    document.getElementById("toolname").value = selectedToolName;

    const existingMap = JSON.parse(document.getElementById("existingMap").value);

    // Find the LO by name
    let selectedLO = null;
    let actualLOIndex = -1;
    const theme = themeData[0].themes[selectedThemeIndex];
    
    theme.learningOutcome.forEach((lo, index) => {
        if (lo.learningOutcomeName === selectedLOName) {
            selectedLO = lo;
            actualLOIndex = index;
            console.log("Found LO at index:", index);
        }
    });

    if (!selectedLO) {
        console.log("LO not found");
        tables[0].style.display = "none";
        return;
    }

    console.log("Selected LO:", selectedLO.learningOutcomeName);

    // Find the aspect within this LO's assessmentAspects that matches the selected aspect name
    const aspectIndex = selectedLO.assessmentAspects.findIndex(
        aspect => aspect.aspectName === selectedAspectName
    );
    console.log("Aspect Index within LO:", aspectIndex);

    if (aspectIndex === -1) {
        console.log("No matching aspect found in this Learning Outcome");
        tables[0].style.display = "none";
        return;
    }

    // Get the tools from the correct aspect
    const tools = selectedLO.assessmentAspects[aspectIndex].tools;
    console.log("Tools found:", tools);

    if (!tools || tools.length === 0) {
        console.log("No tools found for this aspect");
        tables[0].style.display = "none";
        return;
    }

    const indicators = tools[0].indicators;
    console.log("Indicators found:", indicators);

    studentData.forEach((student, i) => {
        indicatorTDs[i].innerHTML = "";
        obtmarksbeforeTDs[i].innerHTML = "";
        obtmarksafterTDs[i].innerHTML = "";

        const key = `${student.reg}|${theme.themeName}|${selectedLO.learningOutcomeName}|${selectedAspectName}|${selectedToolName}`;

        const existingRecord = existingMap[key];
        console.log("Existing Record:", existingRecord);

        if (existingRecord) {
            document.querySelectorAll(".studentDateBefore")[i].value = existingRecord?.evalDateBefore || "";
            document.querySelectorAll(".studentDateAfter")[i].value = existingRecord?.evalDateAfter || "";
        }

        indicators.forEach((indicator, index) => {
            // Indicator name
            const indicatorName = document.createElement("div");
            indicatorName.className = "indicator-name";
            indicatorName.textContent = indicator.indicatorName;
            indicatorTDs[i].appendChild(indicatorName);

            const indicatorDivider = document.createElement("div");
            indicatorDivider.className = "indicator-separator";
            indicatorTDs[i].appendChild(indicatorDivider);
            
            // BEFORE RADIO
            const beforeLabel = document.createElement("label");
            beforeLabel.className = "mark-option-button";
            beforeLabel.htmlFor = `before_${i}_${index}`;

            const radioBefore = document.createElement("input");
            radioBefore.type = "radio";
            radioBefore.name = `students[${student.reg}][obtainedMarksBefore]`;
            radioBefore.value = indicator.maxMarks;
            radioBefore.id = `before_${i}_${index}`;
            radioBefore.addEventListener("change", function () {
            
    const afterRadios = document.querySelectorAll(
    `input[name="students[${student.reg}][obtainedMarksAfter]"]`
    );

    afterRadios.forEach(r => r.checked = false);

if (this.value === "4") {
    const match = [...afterRadios].find(r => r.value === "4");
    if (match) match.checked = true;
}
    });


            if (existingRecord && Number(existingRecord.obtainedMarksBefore) === Number(indicator.maxMarks)) {
                console.log(`Checking radio for indicator ${index} with maxMarks ${indicator.maxMarks}`);
                radioBefore.checked = true;
            }

            const beforeValue = document.createElement("span");
            beforeValue.className = "mark-option-label";
            beforeValue.textContent = indicator.maxMarks;

            beforeLabel.appendChild(radioBefore);
            beforeLabel.appendChild(beforeValue);
            obtmarksbeforeTDs[i].appendChild(beforeLabel);

            // AFTER RADIO
            const afterLabel = document.createElement("label");
            afterLabel.className = "mark-option-button";
            afterLabel.htmlFor = `after_${i}_${index}`;

            const radioAfter = document.createElement("input");
            radioAfter.type = "radio";
            radioAfter.name = `students[${student.reg}][obtainedMarksAfter]`;
            radioAfter.value = indicator.maxMarks;
            radioAfter.id = `after_${i}_${index}`;

            if (existingRecord && Number(existingRecord.obtainedMarksAfter) === Number(indicator.maxMarks)) {
                console.log(`Checking radio for indicator ${index} with maxMarks ${indicator.maxMarks}`);
                radioAfter.checked = true;
            }

            const afterValue = document.createElement("span");
            afterValue.className = "mark-option-label";
            afterValue.textContent = indicator.maxMarks;

            afterLabel.appendChild(radioAfter);
            afterLabel.appendChild(afterValue);
            obtmarksafterTDs[i].appendChild(afterLabel);
        });
    });
}
    </script>

<script>
 function changeLo() {
    const selectedThemeIndex = document.getElementById("themeselect").selectedOptions[0].dataset.themeindex;
    const selectedLOName = document.getElementById("learningoutcomeselect").value;
    
    console.log("Selected LO Name:", selectedLOName);
    
    if (selectedLOName && selectedLOName !== "Select Learning Outcome") {
        // Find the actual LO index by name
        const themeData = JSON.parse(document.getElementById("themeData").value);
        const theme = themeData[0].themes[selectedThemeIndex];
        
        let foundLOIndex = -1;
        theme.learningOutcome.forEach((lo, index) => {
            if (lo.learningOutcomeName === selectedLOName) {
                foundLOIndex = index;
                console.log("Found LO at index:", index);
            }
        });
        
        if (foundLOIndex >= 0) {
            document.getElementById('selectedLOName').value = selectedLOName;
            showTable();
        } else {
            console.log("LO not found in theme");
            document.querySelector(".themeTable").style.display = "none";
        }
    } else {
        document.querySelector(".themeTable").style.display = "none";
    }
}
</script>
   <script src="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/js/nepali.datepicker.v5.0.6.min.js" type="text/javascript"></script>
        <script type="text/javascript">
            window.onload = function() {
                initializeDatePickers();
            };
        </script>


<script>
   function initializeDatePickers() {
    document.querySelectorAll('.nepali-datepicker').forEach(input => {
        try {
            input.nepaliDatePicker();
        } catch(e) {
            console.warn('Could not initialize date picker for:', input.id);
        }
    });
}
</script>



<script>
    //fire events
document.getElementById("learningoutcomeselect").addEventListener("change", function() {
    changeLo();
    document.getElementById("toolselect").selectedIndex = 0; // Reset tool selection

});
document.getElementById("toolselect").addEventListener("change", function() {
    showTable();
});
document.getElementById("themeselect").addEventListener("change", function() {
    filterLO();
    document.getElementById("learningoutcomeselect").selectedIndex = 0; // Reset LO selection
    document.getElementById("toolselect").selectedIndex = 0; // Reset tool selection
    document.getElementById("aspectselect").selectedIndex = 0; // Reset aspect selection
    document.querySelector(".themeTable").style.display = "none"; // Hide table
});


document.getElementById("aspectselect").addEventListener("change", function() {
     
  document.getElementById("learningoutcomeselect").selectedIndex = 0;
    document.getElementById("toolselect").selectedIndex = 0;
    //hide the table

   
});


    </script>


    <script>
function filterAspect() {
    const selectedAspect = document.getElementById("aspectselect").value;
    console.log("Selected Aspect:", selectedAspect);

    const selectedThemeIndex = document.getElementById("themeselect")
        .selectedOptions[0].dataset.themeindex;

    const learningOutcomeSelect = document.getElementById("learningoutcomeselect");
    learningOutcomeSelect.innerHTML = "";

    // default option
    const defaultOption = document.createElement("option");
    defaultOption.textContent = "Select Learning Outcome";
    defaultOption.disabled = true;
    defaultOption.selected = true;
    learningOutcomeSelect.appendChild(defaultOption);

    const selectedTheme = themeData[0].themes[selectedThemeIndex];

    let foundLOs = [];
    selectedTheme.learningOutcome.forEach((lo, index) => {
        const hasAspect = lo.assessmentAspects.some(aspect => 
            aspect.aspectName === selectedAspect
        );

        if (hasAspect) {
            foundLOs.push({
                index: index,
                name: lo.learningOutcomeName
            });
            const option = document.createElement("option");
            option.value = lo.learningOutcomeName;
            option.textContent = lo.learningOutcomeName;
            learningOutcomeSelect.appendChild(option);
        }
    });

    console.log("Available Learning Outcomes for this aspect:", foundLOs);
}
    </script>

    <script>
        
        function loadDate() {
            const masterDateBefore = document.querySelector(".masterDateBefore").value;
            const masterDateAfter = document.querySelector(".masterDateAfter").value;

            document.querySelectorAll(".studentDateBefore").forEach(input => {
                input.value = masterDateBefore;
            });

            document.querySelectorAll(".studentDateAfter").forEach(input => {
                input.value = masterDateAfter;
            });
        }
    </script>
</body>
</html>