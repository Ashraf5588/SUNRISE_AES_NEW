    // Defaults handling: redirect to saved defaults, apply query params to form, and populate data
    document.addEventListener('DOMContentLoaded', function() {
      try {
        const params = new URLSearchParams(window.location.search);
        const subjectParam = params.get('subject');
        const classParam = params.get('studentClass');
        const sectionParam = params.get('section');

        // If no query params but defaults are saved, redirect to include them
        if (!subjectParam && !classParam && !sectionParam) {
          const saved = localStorage.getItem('themeformDefaults');
          if (saved) {
            const obj = JSON.parse(saved);
            const q = new URLSearchParams(obj).toString();
            if (q) {
              // preserve current path
              window.location.search = q;
              return;
            }
          }
        }

        // If query params exist, set the form fields and populate
        if (subjectParam || classParam || sectionParam) {
          const subjEl = document.getElementById('subject');
          const clsEl = document.getElementById('studentClass');
          const secEl = document.getElementById('section');
          const subjHidden = document.getElementById('subjectHidden');
          const classHidden = document.getElementById('studentClassHidden');
          const sectionHidden = document.getElementById('sectionHidden');

          if (subjEl && subjectParam) subjEl.value = subjectParam;
          if (clsEl && classParam) clsEl.value = classParam;
          if (secEl && sectionParam) secEl.value = sectionParam;
          if (subjHidden && subjectParam) subjHidden.value = subjectParam;
          if (classHidden && classParam) classHidden.value = classParam;
          if (sectionHidden && sectionParam) sectionHidden.value = sectionParam;

          // Sync hidden fields and attempt to open first theme view
          setTimeout(() => {
            try { syncHiddenFields(); } catch (e) { console.warn('syncHiddenFields missing', e); }
            const themeSel = document.getElementById('themeName');
            if (themeSel && themeSel.options.length > 1) {
              // don't force selection if already set
              if (!themeSel.value) themeSel.selectedIndex = 1;
              try { filterLearningOutcomes(themeSel, 0); } catch (e) { console.warn('filterLearningOutcomes failed', e); }
            }
          }, 250);
        }

        // Button handlers
        const setBtn = document.getElementById('setDefaultsBtn');
        const clearBtn = document.getElementById('clearDefaultsBtn');
        const openBtn = document.getElementById('openWithDefaultsBtn');

        if (setBtn) setBtn.addEventListener('click', function() {
          const def = {
            subject: (document.getElementById('subject') && document.getElementById('subject').value) || 'NEPALI',
            studentClass: (document.getElementById('studentClass') && document.getElementById('studentClass').value) || 'Three',
            section: (document.getElementById('section') && document.getElementById('section').value) || 'CRIMSON',
            terminal: ''
          };
          localStorage.setItem('themeformDefaults', JSON.stringify(def));
          alert('Defaults saved. Visiting /themeform will redirect with these defaults.');
        });

        if (clearBtn) clearBtn.addEventListener('click', function() { localStorage.removeItem('themeformDefaults'); alert('Defaults cleared'); });

        if (openBtn) openBtn.addEventListener('click', function() {
          const saved = localStorage.getItem('themeformDefaults');
          if (!saved) { alert('No defaults saved. Click "Set Default" first.'); return; }
          const obj = JSON.parse(saved);
          const q = new URLSearchParams(obj).toString();
          window.location.href = window.location.pathname + (q ? ('?' + q) : '');
        });

      } catch (err) { console.warn('Defaults handler failed', err); }
    });
