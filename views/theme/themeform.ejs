  if (loIdx === '' || loIdx === null || toolIdx === '' || toolIdx === null || !selectedIndicatorName) {
    alert('Select LO, tool and one indicator');
    return;
  }

  // Get the LO name from the select dropdown
  const quickLO = document.getElementById('quickLO');
  const quickLOText = (quickLO && quickLO.options[quickLO.selectedIndex] ? quickLO.options[quickLO.selectedIndex].text : '') || '';
  
  if (!quickLOText) {
    alert('Please select a learning outcome');
    return;
  }

  // Determine theme index from existing nested inputs first, then fall back to saved student theme data.
  const formElem = document.getElementById('themeEvaluationForm');
  let themeIndex = -1;
  const themeNameInputs = Array.from(formElem.querySelectorAll('input[name^="subjects[0][themes]["][name$="[themeName]"]'));
  themeNameInputs.forEach(input => {
    const match = input.name.match(/^subjects\[0\]\[themes\]\[(\d+)\]\[themeName\]$/);
    if (match && input.value === theme) {
      themeIndex = Number(match[1]);
    }
  });

  if (themeIndex === -1 && window.studentThemeData && Array.isArray(window.studentThemeData)) {
    const savedThemeIndex = window.studentThemeData.findIndex(t => t.themeName === theme);
