      fd.set('themeName', document.getElementById('themeNameHidden').value || document.getElementById('themeName').value || '');
      fd.set('autosave', 'true');

      const urlEncoded = new URLSearchParams();
      for (const pair of fd.entries()) urlEncoded.append(pair[0], pair[1]);

      const resp = await fetch('/themeform', {
        method: 'POST',
        body: urlEncoded.toString(),
        headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' }
      });
      if (!resp.ok) console.error('Save failed HTTP:', resp.status);
      else {
        const j = await resp.json();
