          const acAspects = Array.isArray(window.aspectContainerAspects) ? window.aspectContainerAspects : [];
          let matched = null;
          for (let ai = 0; ai < acAspects.length; ai++) {
            const a = acAspects[ai];
            const name = (a && (a.aspectName || a.name)) || String(a || '');
            if (name === selectedAspectName) { matched = a; break; }
          }
          if (matched && Array.isArray(matched.tools)) {
            matched.tools.forEach(t => {
              const tname = (t && (t.toolName || t.name)) || String(t || '');
              const opt = document.createElement('option');
              opt.value = tname;
              opt.textContent = tname;
              toolsSelect.appendChild(opt);
            });
          }
          toolsSelect.addEventListener('change', function() {
            const hiddenTool = row.querySelector('input[type="hidden"][name*="[tools]"]');
            if (hiddenTool) hiddenTool.value = this.value;
          });
        } catch (e) { console.warn('populate tools failed', e); }
      });
      // If select has a preselected value (existing data), trigger change to populate tools
      if (select.value) {
        try { select.dispatchEvent(new Event('change')); } catch(e) { console.warn('trigger aspect change failed', e); }
      }
    });
  } catch (err) {
    console.error('Failed to load aspects', err);
  }
});

function populateSelect(select) {
  // don't populate tool suggestions into pure aspect selects or selects driven by AspectContainer
  // If a select has both 'aspect-dropdown' and 'tools-dropdown', treat it as a tools select.
  if (select.classList && ((select.classList.contains('aspect-dropdown') && !select.classList.contains('tools-dropdown')) || select.dataset.aspectDriven === '1')) return;
  // If Nepali uses AspectContainer for tools, do not populate generic tool selects here
  if (window.useAspectContainerForTools && select.classList && select.classList.contains('tools-dropdown') && select.dataset.aspectDriven !== '1') return;
  // If this quickTool is forced to use the global tools collection for English, do not overwrite it here
  if (select.id === 'quickTool' && select.dataset && select.dataset.forceGlobal === '1') return;
    // preserve first option
    const firstOption = select.options[0];
    select.innerHTML = '';
    select.appendChild(firstOption);
    
    const useIndex = (select.id === 'quickTool' || select.dataset.useIndex === '1');
    // If no tools available yet, skip population — may be populated later
    if (!Array.isArray(window.globalToolsList) || window.globalToolsList.length === 0) return;
    (window.globalToolsList || []).forEach((tool, idx) => {
      const opt = document.createElement('option');
      if (useIndex) opt.value = idx;
      else {
        const label = (typeof tool === 'string') ? tool.trim() : (tool.toolName || tool.name || String(idx));
        opt.value = label;
      }
      opt.textContent = (typeof tool === 'string') ? tool.trim() : (tool.toolName || tool.name || `Tool ${idx+1}`);
      select.appendChild(opt);
    });
}

function addToolFromSelect(selectElement) {
  const selVal = selectElement.value;
  if (selVal === undefined || selVal === null || selVal === '') return;
  const toolName = (Array.isArray(window.globalToolsList) && window.globalToolsList[Number(selVal)]) ? window.globalToolsList[Number(selVal)] : selVal;
    
    const wrapper = selectElement.closest('.tools-input-wrapper');
    const hiddenInput = wrapper.querySelector('input.tools-value-storage');
    
    let currentVal = hiddenInput.value ? hiddenInput.value.split(',').map(s => s.trim()).filter(Boolean) : [];
    
    if(!currentVal.includes(toolName)) {
        currentVal.push(toolName);
        hiddenInput.value = currentVal.join(',');
        
        // Trigger events
        hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
        hiddenInput.dispatchEvent(new Event('input', { bubbles: true }));
    }
    
    // Reset select
    selectElement.value = "";
}

// Ensure tool selects get populated when focused or added dynamically
document.addEventListener('DOMContentLoaded', () => {
  // Populate on focus (covers user clicking a select after initial load)
  document.body.addEventListener('focusin', (e) => {
    try {
      const el = e.target;
      if (!el) return;
      if ((el.matches && (el.matches('select.tools-dropdown') || el.matches('select#quickTool'))) ) {
        if (el.options.length <= 1) populateSelect(el);
      }
    } catch (err) { /* ignore */ }
  });

  // Observe DOM additions to populate newly inserted selects
  const mo = new MutationObserver((mutations) => {
    mutations.forEach(m => {
      m.addedNodes.forEach(node => {
        try {
          if (node.querySelectorAll) {
            const selects = node.querySelectorAll('select.tools-dropdown, select#quickTool');
            selects.forEach(s => { if (s.options.length <= 1) populateSelect(s); });
          }
          if (node.matches && (node.matches('select.tools-dropdown') || node.matches('select#quickTool'))) {
            if (node.options.length <= 1) populateSelect(node);
          }
        } catch (e) {}
      });
    });
  });
  mo.observe(document.body, { childList: true, subtree: true });
});

function renderTools(hiddenInput) {
    const val = hiddenInput.value || '';
    const tools = val.split(',').map(s => s.trim()).filter(Boolean);
    const wrapper = hiddenInput.closest('.tools-input-wrapper');
    if(!wrapper) return; 

    const tagsArea = wrapper.querySelector('.tools-tags-area');
    
    // Remove existing tags
    tagsArea.innerHTML = '';
    
    tools.forEach(tool => {
        const tag = document.createElement('div');
        tag.className = 'tool-tag';
        tag.innerHTML = `<span>${tool}</span> <span class="remove-tool" onclick="event.stopPropagation(); removeToolTag(this.parentNode)">×</span>`;
        tagsArea.appendChild(tag);
    });
}

function removeToolTag(tagElement) {
    const toolNameSpan = tagElement.querySelector('span');
    const toolName = toolNameSpan ? toolNameSpan.textContent : '';
    const wrapper = tagElement.closest('.tools-input-wrapper');
    const hiddenInput = wrapper.querySelector('input.tools-value-storage');
    
    let currentVal = hiddenInput.value ? hiddenInput.value.split(',').map(s => s.trim()) : [];
    currentVal = currentVal.filter(t => t !== toolName);
    
    hiddenInput.value = currentVal.join(','); 
    hiddenInput.dispatchEvent(new Event('change', { bubbles: true })); // Trigger autosave
    hiddenInput.dispatchEvent(new Event('input', { bubbles: true }));
}
</script>
<script>
  // Expose key functions to window so inline handlers can access them
  try {
    if (typeof syncHiddenFields === 'function') window.syncHiddenFields = syncHiddenFields;
    if (typeof filterLearningOutcomes === 'function') window.filterLearningOutcomes = filterLearningOutcomes;
    if (typeof onLOChange === 'function') window.onLOChange = onLOChange;
    if (typeof onAspectChange === 'function') window.onAspectChange = onAspectChange;
    if (typeof onToolChange === 'function') window.onToolChange = onToolChange;
    if (typeof populateQuickSelects === 'function') window.populateQuickSelects = populateQuickSelects;
    if (typeof populateSelect === 'function') window.populateSelect = populateSelect;
  } catch (e) {
    console.warn('Exposing global handlers failed', e);
  }

  (function () {
    const checkbox = document.getElementById('nepaliToggle');
    const track = document.getElementById('themeFormToggleTrack');
    const thumb = document.getElementById('themeFormToggleThumb');
    if (!checkbox || !track || !thumb) return;

    const syncVisual = () => {
      thumb.style.transform = checkbox.checked ? 'translateX(26px)' : 'translateX(0)';
      track.style.backgroundColor = checkbox.checked ? '#4caf50' : '#cfd8dc';
    };

    checkbox.addEventListener('change', syncVisual);
    document.addEventListener('DOMContentLoaded', syncVisual);
    syncVisual();
  })();
</script>
<script src="/js/preeti.js"></script>
<script src="/js/preeti-input-toggle.js"></script>
