    /* Responsive select and input fixes */
@media (max-width: 900px) {
  .evaluation-table {
    font-size: 0.8rem;
    overflow-x: auto;
    display: block;
  }

  .evaluation-table thead,
  .evaluation-table tbody,
  .evaluation-table tr {
    display: block;
  }

  .evaluation-table th,
  .evaluation-table td {
    padding: 0.5rem 0.25rem;
    text-align: left;
  }

  .evaluation-table th {
    font-size: 0.75rem;
    padding: 0.5rem 0.25rem;
  }

  .evaluation-table tr {
    margin-bottom: 0.5rem;
    border: 1px solid #ecf0f1;
    border-radius: 8px;
    overflow: hidden;
  }

  .marks-input {
    width: 35px;
    padding: 0.4rem 0.2rem;
  }

  .btn-increment,
  .btn-decrement {
    width: 22px;
    height: 22px;
    font-size: 14px;
  }

  .learning-outcome-wrapper-header h2 {
    font-size: 1.1rem;
  }

  select {
    width: 100%;
    min-width: 0;
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    box-sizing: border-box;
  }
  input[type="text"],
  input[type="number"],
  input[type="date"] {
    width: 100%;
    min-width: 0;
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 10px;
    box-sizing: border-box;
  }
  .evaluation-table td input[type="text"],
  .evaluation-table td input[type="number"] {
    width: 100%;
    min-width: 0;
    font-size: 0.9rem;
    padding: 0.4rem 0.3rem;
    border-radius: 6px;
    box-sizing: border-box;
  }
}
@media (max-width: 600px) {
  .evaluation-table {
    font-size: 0.7rem;
