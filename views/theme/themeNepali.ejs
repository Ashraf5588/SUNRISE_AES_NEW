<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Math</title>
  <link rel="stylesheet" href="/form.css">
  <link rel="stylesheet" href="/mobile-form-enhancements.css">
 <script src="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/js/nepali.datepicker.v5.0.6.min.js" type="text/javascript"></script>
 <link href="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/css/nepali.datepicker.v5.0.6.min.css" rel="stylesheet" type="text/css"/>
</head>
<body>

  <form action="/themeform?studentClass=<%= studentClass %>&section=<%= section %>&subject=<%= subject %>" method="POST">
  
    Select theme:
    <select id="themeselect" onchange="filterLO()">
      <option disabled selected>Select Theme</option>
      <%themeData.forEach(data => { %>
        <% data.themes.forEach((theme,themeIndex) => { %>
          <option value="<%= theme.themeName %>" data-themeIndex="<%= themeIndex %>"><%= theme.themeName %></option>
        <% }); %>
      <% }); %>
   
    </select>
     <select id="learningoutcomeselect" onchange="changeLo()">
        <option disabled selected>Select Learning Outcome</option>
    </select>

    <select id="aspectselect" onchange="showTools()" name="aspectName">
      <option disabled selected>Select Aspect</option>
     <%aspectcontainerData.aspects.forEach((aspect, aspectIndex) => { %>
        <option value="<%= aspect.aspectName %>" data-aspectIndex="<%= aspectIndex %>"><%= aspect.aspectName %></option>
      <% }); %>
    </select>
  
     <select id="toolselect" onchange="showTable()">
      <option selected disabled>Select Tool </otpion>  
    </select>
<input type="hidden" value="<%=JSON.stringify(themeData)%>" id="themeData">

<input type="submit">

<input type="hidden" id="existingMap" value="<%=JSON.stringify(existingMap)%>"

 <th>Eval.Date Before: <input type="text" id="nepali-datepicker" class="masterDateBefore nepali-datepicker" placeholder="Select Nepali Date" /></th>
 <th>Eval.Date After: <input type="text" id="nepali-datepicker" class="masterDateAfter nepali-datepicker" placeholder="Select Nepali Date" /></th>
<input type="hidden" value="<%=JSON.stringify(aspectcontainerData) %>" id="aspectcontainerData">

  <table border="1" style="display:none;" cellspacing="0" cellpadding="5" class="themeTable" >
  

    <tr>
      <th>Name</th>
        <th>Eval.Date Before</th>
      <th>Indicator</th>
      <th>Obt.Marks Before</th>
      <th>Obt.Marks After</th>
      <th>Eval.Date After</th>
      
    </tr>
 <input type="hidden" value="<%= studentClass%>" name="studentClass">
           <input type="hidden" value="<%= section%>" name="section">
       <input type="hidden" value="<%= subject%>" name="subject">
    <input type="hidden"  id="selectedThemeName" name="themeName">
<input type="hidden"  id="selectedLOName" name="learningOutcomeName">
<input type="hidden"  id="toolname" name="toolName">

      <% studentData.forEach((record, idx) => { %>
    <tr>
      <td><%= record.name %></td>
       <input type="hidden" value="<%= record.reg%>" name="reg">
      <input type="hidden" value="<%= record.name%>" name="name">
      <input type="hidden" value="<%= record.roll%>" name="roll">
     

       

       <td><input type="text" id="nepali-datepicker-<%= idx %>" placeholder="Select Nepali Date"  class="studentDateBefore nepaliDateBefore nepali-datepicker" name="evalDateBefore" /></td>
      <td id="indicatorTD"></td>
      <input type="hidden" id="selectedIndicatorBefore">
       <input type="hidden" id="selectedIndicatorAfter">
      <td id="obtmarksbefore"></td>
      <td id="obtmarksafter"></td>
      <td><input type="text" id="nepali-datepicker-<%= idx %>" placeholder="Select Nepali Date"  
        class="studentDateAfter nepaliDateAfter nepali-datepicker" name="evalDateAfter"/></td>
    </tr>
    <%});%>
  </table> <br>

    </form>
<input type="hidden" value="<%=JSON.stringify(studentData)%>" id="studentData">
  <script>
const themeData = <%- JSON.stringify(themeData) %>;

function filterLO() {
    const selectedOption =
        document.querySelector('#themeselect option:checked');

    const selectedThemeIndex =
        Number(selectedOption.dataset.themeindex);

        // adding name for selected theme to save in db

        document.getElementById('selectedThemeName').value = themeData[0].themes[selectedThemeIndex].themeName;
          

         


        

    const learningOutcomeSelect =
        document.getElementById('learningoutcomeselect');

    learningOutcomeSelect.innerHTML = '';

    const selectedTheme =
        themeData[0].themes[selectedThemeIndex];
        
 const defaultLOoption = document.createElement('option');
 defaultLOoption.textContent="select Learning Outcome";
 defaultLOoption.disabled = true;
 defaultLOoption.selected = true;
 learningOutcomeSelect.appendChild(defaultLOoption);
    selectedTheme.learningOutcome.forEach(lo => {
        const option = document.createElement('option');

        option.value = lo.learningOutcomeName;
        option.textContent = lo.learningOutcomeName;

        learningOutcomeSelect.appendChild(option);
        
    });
}

</script>

<script>
  function showTools() {
    const selectedAspectIndex =
        document.getElementById("aspectselect").selectedOptions[0].dataset.aspectindex;

    const toolsSelectbtn = document.getElementById("toolselect");
    toolsSelectbtn.innerHTML = '<option disabled selected>Select Tool</option>';

    const aspectcontainerData = JSON.parse(document.getElementById("aspectcontainerData").value);

    aspectcontainerData.aspects[selectedAspectIndex].tools.forEach((tool, toolIndex) => {
        const option = document.createElement("option");
        option.value = tool.toolName;
        option.textContent = tool.toolName;
        option.dataset.toolindex = toolIndex;
        toolsSelectbtn.appendChild(option);
    });
  }
</script>

<script>
  function changeLo() {
    const selectedThemeIndex =
        document.getElementById("themeselect").selectedOptions[0].dataset.themeindex;

    const selectedLOIndex =
        document.getElementById("learningoutcomeselect").selectedIndex-1;
        console.log("Selected LO Index:", selectedLOIndex);

    // adding name for selected lo to save in db
    // document.getElementById('selectedLOName').name = `subjects[0][themes][${selectedThemeIndex}][learningOutcome][${selectedLOIndex}][learningOutcomeName]`;
    document.getElementById('selectedLOName').value = themeData[0].themes[selectedThemeIndex].learningOutcome[selectedLOIndex].learningOutcomeName;
  }
</script>
<script>
function showTable() {
    const tables = document.querySelectorAll(".themeTable");
    const indicatorTDs = document.querySelectorAll("#indicatorTD");
    const obtmarksbeforeTDs = document.querySelectorAll("#obtmarksbefore");
    const obtmarksafterTDs = document.querySelectorAll("#obtmarksafter");



    const selectedThemeIndex =
        document.getElementById("themeselect")
            .selectedOptions[0]
            .dataset.themeindex;

    const selectedLOIndex =
        document.getElementById("learningoutcomeselect").selectedIndex - 1;

    tables[0].style.display = "table"; // Show table

    const studentData =
        JSON.parse(document.getElementById("studentData").value);

    const selectedToolName =
        document.getElementById("toolselect").value;

    document.getElementById("toolname").value =
        selectedToolName;
        const aspectcontainerData = JSON.parse(document.getElementById("aspectcontainerData").value);
        const aspectIndex = document.getElementById("aspectselect").selectedIndex-1;
        console.log("Selected Aspect Index:", aspectIndex);
        const toolIndex = document.getElementById("toolselect").selectedIndex-1;
        console.log("Selected Tool Index:", toolIndex);

    const existingMap =
        JSON.parse(document.getElementById("existingMap").value);

    studentData.forEach((student, i) => {

        indicatorTDs[i].innerHTML = "";
        obtmarksbeforeTDs[i].innerHTML = "";
        obtmarksafterTDs[i].innerHTML = "";

        const key =
            `${student.reg}|` +
            `${themeData[0].themes[selectedThemeIndex].themeName}|` +
            `${themeData[0].themes[selectedThemeIndex]
                .learningOutcome[selectedLOIndex]
                .learningOutcomeName}|` + `${aspectcontainerData.aspects[aspectIndex].aspectName}|` +
            `${selectedToolName}`;

        const existingRecord = existingMap[key];

        console.log("Existing Record:", existingRecord);
      if (existingRecord) {
    document.querySelectorAll(".studentDateBefore")[i].value =
        existingRecord?.evalDateBefore || "";

    document.querySelectorAll(".studentDateAfter")[i].value =
        existingRecord?.evalDateAfter || "";
}

        
            aspectcontainerData.aspects[aspectIndex].tools[toolIndex].indicators
            .forEach((indicator, index) => {

                // Indicator name
                const indicatorName = document.createElement("div");
                indicatorName.className = "indicator-name";
                indicatorName.textContent = indicator.indicatorName;
                indicatorTDs[i].appendChild(indicatorName);

                const indicatorDivider = document.createElement("div");
                indicatorDivider.className = "indicator-separator";
                indicatorTDs[i].appendChild(indicatorDivider);
                // BEFORE RADIO (wrapped in a touch-friendly button label)
                const beforeLabel = document.createElement("label");
                beforeLabel.className = "mark-option-button";
                beforeLabel.htmlFor = `before_${i}_${index}`;

                const radioBefore = document.createElement("input");
                radioBefore.type = "radio";
                radioBefore.name = `students[${student.reg}][obtainedMarksBefore]`;
                radioBefore.value = indicator.maxMarks;
                radioBefore.id = `before_${i}_${index}`;

                if (
                    existingRecord &&
                    Number(existingRecord.obtainedMarksBefore) ===
                    Number(indicator.maxMarks)
                ) {
                    radioBefore.checked = true;
                }

                const beforeValue = document.createElement("span");
                beforeValue.className = "mark-option-label";
                beforeValue.textContent = indicator.maxMarks;

                beforeLabel.appendChild(radioBefore);
                beforeLabel.appendChild(beforeValue);
                obtmarksbeforeTDs[i].appendChild(beforeLabel);

                // AFTER RADIO (wrapped in a touch-friendly button label)
                const afterLabel = document.createElement("label");
                afterLabel.className = "mark-option-button";
                afterLabel.htmlFor = `after_${i}_${index}`;

                const radioAfter = document.createElement("input");
                radioAfter.type = "radio";
                radioAfter.name = `students[${student.reg}][obtainedMarksAfter]`;
                radioAfter.value = indicator.maxMarks;
                radioAfter.id = `after_${i}_${index}`;

                if (
                    existingRecord &&
                    Number(existingRecord.obtainedMarksAfter) ===
                    Number(indicator.maxMarks)
                ) {
                    radioAfter.checked = true;
                }

                const afterValue = document.createElement("span");
                afterValue.className = "mark-option-label";
                afterValue.textContent = indicator.maxMarks;

                afterLabel.appendChild(radioAfter);
                afterLabel.appendChild(afterValue);
                obtmarksafterTDs[i].appendChild(afterLabel);
            });
    });
}


</script>
   <script src="https://nepalidatepicker.sajanmaharjan.com.np/v5/nepali.datepicker/js/nepali.datepicker.v5.0.6.min.js" type="text/javascript"></script>
        <script type="text/javascript">
            window.onload = function() {
                initializeDatePickers();
            };
        </script>


<script>
   function initializeDatePickers() {
    document.querySelectorAll('.nepali-datepicker').forEach(input => {
        try {
            input.nepaliDatePicker();
        } catch(e) {
            console.warn('Could not initialize date picker for:', input.id);
        }
    });
}
</script>



<script>
    //fire events
    document.getElementById("aspectselect").addEventListener("change", function() {
    const table = document.querySelector(".themeTable");
    table.style.display = "none"; 
        showTools();
});

document.getElementById("learningoutcomeselect").addEventListener("change", function() {
    changeLo();
    document.getElementById("toolselect").selectedIndex = 0;
});
document.getElementById("toolselect").addEventListener("change", function() {
 const table = document.querySelector(".themeTable");
      table.style.display = "table";
    showTable();
});
document.getElementById("themeselect").addEventListener("change", function() {
    filterLO();
    document.getElementById("learningoutcomeselect").selectedIndex = 0; // Reset LO selection
    document.getElementById("toolselect").selectedIndex = 0; // Reset tool selection
    document.querySelector(".themeTable").style.display = "none"; // Hide table
});

    </script>
</body>
</html>